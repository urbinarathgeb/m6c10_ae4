<section class="hero">
	<h1>GameVibe: Catálogo de Reseñas</h1>
	<p>Descubre tu próxima aventura épica entre nuestra selección de juegos.</p>
</section>

<div class="container">
	<div class="games-grid">

		{{#each games}}
			{{> card this}}
		{{else}}
			<div class="empty-state">
				<p>No se encontraron videojuegos en la base de datos.</p>
			</div>
		{{/each}}
	</div>
</div>